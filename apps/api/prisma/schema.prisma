generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───

enum PlaceType {
  ATTRACTION
  RESTAURANT
  ACTIVITY
}

enum BudgetTier {
  LOW
  MEDIUM
  HIGH
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  NONE
}

enum GoaRegion {
  NORTH
  CENTRAL
  SOUTH
}

// ─── MODELS ───

model User {
  id          String      @id @default(cuid())
  email       String      @unique
  name        String?
  avatarUrl   String?

  itineraries Itinerary[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("users")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  places    Place[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Place {
  id                       String     @id @default(cuid())
  name                     String
  description              String?
  imageUrl                 String?

  latitude                 Float
  longitude                Float

  type                     PlaceType
  categoryId               String
  category                 Category   @relation(fields: [categoryId], references: [id])
  region                   GoaRegion

  estimatedDurationMinutes Int        @default(60)
  bestTimeStart            String?    @default("09:00")
  bestTimeEnd              String?    @default("18:00")
  isOpenAtNight            Boolean    @default(false)

  budgetTier               BudgetTier @default(MEDIUM)
  avgCostPerPerson         Float?
  mealType                 MealType   @default(NONE)
  tags                     String[]

  rating                   Float?     @default(0)
  reviewCount              Int        @default(0)

  itinerarySlots           ItinerarySlot[]

  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@index([type])
  @@index([region])
  @@index([budgetTier])
  @@index([categoryId])
  @@map("places")
}

model Itinerary {
  id             String         @id @default(cuid())
  userId         String?
  user           User?          @relation(fields: [userId], references: [id])
  title          String         @default("My Goa Trip")

  numDays        Int
  budget         BudgetTier
  stayLatitude   Float
  stayLongitude  Float
  interests      String[]
  foodPreference String?

  days           ItineraryDay[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
  @@map("itineraries")
}

model ItineraryDay {
  id          String          @id @default(cuid())
  itineraryId String
  itinerary   Itinerary       @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  dayNumber   Int
  date        DateTime?
  slots       ItinerarySlot[]

  @@unique([itineraryId, dayNumber])
  @@map("itinerary_days")
}

model ItinerarySlot {
  id                    String       @id @default(cuid())
  dayId                 String
  day                   ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  slotOrder             Int

  placeId               String
  place                 Place        @relation(fields: [placeId], references: [id])

  startTime             String
  endTime               String
  durationMinutes       Int

  travelFromPrevMinutes Int?
  travelFromPrevKm      Float?
  routeGeometry         String?

  isMealStop            Boolean      @default(false)
  mealType              MealType?

  @@unique([dayId, slotOrder])
  @@map("itinerary_slots")
}
