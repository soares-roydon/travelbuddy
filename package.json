{
  "name": "travelbuddy",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:shared\" \"npm run dev:api\" \"npm run dev:web\"",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:shared": "npm run dev --workspace=@travelbuddy/shared",
    "dev:api": "npm run dev --workspace=@travelbuddy/api",
    "dev:web": "npm run dev --workspace=@travelbuddy/web",
    "db:generate": "npm run db:generate --workspace=@travelbuddy/api",
    "db:migrate": "npm run db:migrate --workspace=@travelbuddy/api",
    "db:seed": "npm run db:seed --workspace=@travelbuddy/api"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^10.0.3",
    "turbo": "^2.9.18",
    "typescript": "^5.8.0"
  },
  "packageManager": "npm@10.9.2"
}
